{
  "Google EditorConfig": {
    "prefix": "googleeditorconfig",
    "body": [
      "root = true",
      "",
      "[*]",
      "charset = utf-8",
      "end_of_line = lf",
      "insert_final_newline = true",
      "trim_trailing_whitespace = true",
      "",
      "[*.{js,jsx,ts,tsx,json,css,scss,html}]",
      "indent_style = space",
      "indent_size = 2",
      "max_line_length = 80",
      "",
      "[*.py]",
      "indent_style = space",
      "indent_size = 4",
      "max_line_length = 80",
      "",
      "[*.md]",
      "trim_trailing_whitespace = false"
    ],
    "description": "Insert a Google-style EditorConfig template"
  }
}
