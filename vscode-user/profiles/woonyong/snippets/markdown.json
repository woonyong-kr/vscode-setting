{
  "Markdown link": {
    "prefix": "mdlink",
    "body": [
      "[${1:text}](${2:url})"
    ],
    "description": "Insert a markdown link"
  },
  "Code fence": {
    "prefix": "codefence",
    "body": [
      "```$1",
      "$2",
      "```"
    ],
    "description": "Insert a fenced code block"
  },
  "Details block": {
    "prefix": "details",
    "body": [
      "<details>",
      "<summary>${1:Summary}</summary>",
      "",
      "${2}",
      "",
      "</details>"
    ],
    "description": "Insert a collapsible details block"
  },
  "Task list item": {
    "prefix": "task",
    "body": [
      "- [ ] ${1:item}"
    ],
    "description": "Insert a markdown task item"
  }
}
